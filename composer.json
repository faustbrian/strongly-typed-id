{
    "name": "cline/strongly-typed-id",
    "description": "Strongly-typed ID value objects for PHP with support for UUID, ULID, NanoID, GUID, Sqid, Hashids and Laravel integration",
    "license": "MIT",
    "keywords": [
        "strongly-typed",
        "value-object",
        "identifier",
        "uuid",
        "ulid",
        "nanoid",
        "guid",
        "sqid",
        "hashids",
        "laravel",
        "eloquent",
        "ddd",
        "domain-driven-design",
        "type-safety"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "hashids/hashids": "^5.0.2",
        "spatie/laravel-data": "^3.0 || ^4.20",
        "spatie/laravel-package-tools": "^1.93.0",
        "sqids/sqids": "^0.5.0"
    },
    "require-dev": {
        "cline/coding-standard": "^2.0",
        "ergebnis/composer-normalize": "^2.50.0",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "symfony/var-dumper": "^7.4.6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\StronglyTypedId\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cline\\StronglyTypedId\\StronglyTypedIdServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": "ecs check --fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ],
        "test:lint": "ecs check",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "pest --parallel --min=80 --type-coverage",
        "test:types": "phpstan",
        "test:unit": "pest --parallel --min=80 --coverage"
    }
}
